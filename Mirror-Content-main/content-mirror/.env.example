# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
APP_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_mirror

# ─── Redis (Queue + Cache) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Storage (S3-compatible) ───────────────────────────────────────────────────
STORAGE_BACKEND=local                  # local | s3 | r2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=content-mirror-uploads
AWS_REGION=us-east-1
LOCAL_UPLOAD_DIR=./uploads

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
AI_MODEL=gemini-2.0-flash

# ─── Vector DB ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=content-mirror-benchmarks
PINECONE_ENV=us-east-1-aws

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_FREE_ANALYSES_PER_MONTH=5
RATE_LIMIT_PRO_ANALYSES_PER_MONTH=100

# ─── Celery Worker ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
